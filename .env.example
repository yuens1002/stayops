# StayOps environment variables — copy to .env.local and fill in.
# See docs/PLAN.md "Dev & verification environment" for provisioning notes.

# --- Neon Postgres (yuens1002 Hobby account, via the Vercel<->Neon integration) ---
DATABASE_URL=

# --- Clerk (dev instance keys from the Clerk dashboard) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Vercel Blob (checklist photo evidence) ---
BLOB_READ_WRITE_TOKEN=

# --- Vercel AI Gateway (model routing; "provider/model" strings) ---
AI_GATEWAY_API_KEY=

# --- Gmail OAuth (v1 core: Airbnb booking-email enrichment; also serves the
# --- Google Voice channel post-golden-path) ---
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=

# --- Post-golden-path enhancements (leave empty until those phases) ---
# xAI key for Grok STT/TTS voice I/O
XAI_API_KEY=
# Owner's Google Voice number (E.164), e.g. +1XXXXXXXXXX
GV_NUMBER=
